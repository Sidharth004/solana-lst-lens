# Copy to .env and fill in. Never commit real values.

# Ironforge gateway key for sanctum-api.ironforge.network (PRIMARY data source).
# Get a free key at https://ironforge.network
SANCTUM_API_KEY=

# Optional. Only needed if raw on-chain validator-list reads are required
# (a pool whose validator list is not exposed via Sanctum + Stakewiz).
HELIUS_RPC_URL=
