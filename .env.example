# Copy to .env and fill in. Never commit real values.
#
# NOTE: the pipeline now runs on KEYLESS public data sources (Sanctum LST-list
# TOML + extra-api.sanctum.so + Stakewiz + DeFiLlama + Jupiter). No API key is
# required to run `pnpm pipeline` or the daily cron.

# RPC for the on-chain reads: decentralization (validator lists), protocol fees,
# and REAL per-validator MEV (Jito tip-distribution accounts — thousands of small
# account reads). Defaults to the public endpoint (api.mainnet-beta.solana.com),
# which is rate-limited: MEV coverage will be partial and the run slow. A free
# Helius (or any dedicated) RPC resolves everything and is much faster.
SOLANA_RPC_URL=
HELIUS_RPC_URL=

# Deprecated / unused: the gated Sanctum data API (sanctum-api.ironforge.network)
# required this, but that key is not self-serve. Left here only for reference.
# SANCTUM_API_KEY=
