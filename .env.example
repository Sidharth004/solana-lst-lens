# Copy to .env and fill in. Never commit real values.
#
# NOTE: the pipeline now runs on KEYLESS public data sources (Sanctum LST-list
# TOML + extra-api.sanctum.so + Stakewiz + DeFiLlama + Jupiter). No API key is
# required to run `pnpm pipeline` or the daily cron.

# Optional. Only needed if you wire the RPC validator-list resolver to compute
# decentralization on real data (reads each pool's on-chain validator list).
HELIUS_RPC_URL=

# Deprecated / unused: the gated Sanctum data API (sanctum-api.ironforge.network)
# required this, but that key is not self-serve. Left here only for reference.
# SANCTUM_API_KEY=
