{
  "name": "lst-dashboard",
  "version": "0.1.0",
  "private": true,
  "description": "Neutral, data-driven comparison dashboard for Solana Liquid Staking Tokens (LSTs).",
  "type": "module",
  "scripts": {
    "pipeline": "tsx pipeline/run.ts",
    "dev": "pnpm --filter web dev",
    "prepare-web-data": "node scripts/prepare-web-data.mjs",
    "build": "pnpm --filter web build",
    "build:site": "node scripts/prepare-web-data.mjs && pnpm --filter web build",
    "typecheck": "tsc -p tsconfig.json --noEmit && pnpm --filter web typecheck"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@10.8.0",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "dependencies": {
    "@solana/web3.js": "^1.98.4",
    "bs58": "^6.0.0",
    "smol-toml": "^1.7.0"
  }
}
